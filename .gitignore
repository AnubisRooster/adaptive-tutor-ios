.env*.local

# typescript
*.tsbuildinfo

# generated native folders (regenerated by `expo prebuild`) — except the
# shared Xcode scheme, committed so "Release" stays the default Run
# configuration across regenerations (see plugins/ for why Debug isn't used).
/ios/*
!/ios/AdaptiveTutor.xcodeproj
/ios/AdaptiveTutor.xcodeproj/*
!/ios/AdaptiveTutor.xcodeproj/xcshareddata
/ios/AdaptiveTutor.xcodeproj/xcshareddata/*
!/ios/AdaptiveTutor.xcodeproj/xcshareddata/xcschemes
/ios/AdaptiveTutor.xcodeproj/xcshareddata/xcschemes/*
!/ios/AdaptiveTutor.xcodeproj/xcshareddata/xcschemes/AdaptiveTutor.xcscheme
/android
